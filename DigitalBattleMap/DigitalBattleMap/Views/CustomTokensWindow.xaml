<Window x:Class="DigitalBattleMap.Views.CustomTokensWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        xmlns:viewmodels="clr-namespace:DigitalBattleMap.ViewModels" 
        xmlns:uielements="clr-namespace:DigitalBattleMap.UIElements" 
        xmlns:dataclasses="clr-namespace:DigitalBattleMap.DataClasses"
        mc:Ignorable="d"
        Title="CustomTokensWindow" Height="600" Width="800"
        FontSize="17"
        WindowStartupLocation="CenterScreen">
    <Window.DataContext>
        <viewmodels:CustomTokensWindowViewModel/>
    </Window.DataContext>
    <Window.Resources>
        <uielements:NullToBoolConverter x:Key="NullConverter"/>
    </Window.Resources>

    <!--Main grid-->
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>

        <TabControl>
            <TabItem>
                <TabItem.Header>
                    <TextBlock Text="Tokens"/>
                </TabItem.Header>
                <!--Tokens grid-->
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!--Search grid-->
                    <Grid Grid.ColumnSpan="3" Margin="0 10 0 0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Label Content="Search"/>
                        <TextBox Grid.Column="1" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center"/>
                    </Grid>
                    <ListView Grid.Row="1" Grid.ColumnSpan="3" Margin="0 10 0 0" ItemsSource="{Binding TokenList}" HorizontalAlignment="Stretch" SelectedItem="{Binding SelectedToken}">
                        <i:Interaction.Behaviors>
                            <uielements:MultiSelectionBehavior SelectedItems="{Binding SelectedTokens, Mode=OneWayToSource}" />
                        </i:Interaction.Behaviors>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Label Content="{Binding Name}"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <Button Grid.Row="2" Content="Remove" Margin="0 10 5 0" IsEnabled="{Binding SelectedToken, Converter={StaticResource NullConverter}}" Command="{Binding RemoveTokenCommand}"/>
                    <Button Grid.Row="2" Grid.Column="1" Content="Edit" Margin="5 10 5 0" IsEnabled="{Binding SelectedToken, Converter={StaticResource NullConverter}}" Command="{Binding EditTokenCommand}"/>
                    <Button Grid.Row="2" Grid.Column="2" Content="Add" Margin="5 10 0 0" Command="{Binding AddTokenCommand}"/>

                    <Grid Grid.Row="3" Grid.ColumnSpan="3" Margin="0 10 0 0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Content="Import" Margin="0 0 5 0" Command="{Binding ImportCommand}"/>
                        <Button Grid.Column="1" Content="Export" Margin="5 0 0 0" IsEnabled="{Binding SelectedToken, Converter={StaticResource NullConverter}}" Command="{Binding ExportCommand}"/>
                    </Grid>
                </Grid>
            </TabItem>
            <TabItem>
                <TabItem.Header>
                    <TextBlock Text="Groups"/>
                </TabItem.Header>
                
                <!--Groups grid-->
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Label Content="Group names" Margin="0 0 5 0"/>
                    <Label Grid.Column="1" Content="Token names" Margin="5 0 0 0"/>
                    <ListView Grid.Row="1" ItemsSource="{Binding GroupList}" HorizontalAlignment="Stretch" SelectedItem="{Binding SelectedGroup}" Margin="0 0 5 0">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Label Content="{Binding Name}"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <ListView Grid.Row="1" Grid.Column="1" ItemsSource="{Binding GroupTokensList}" HorizontalAlignment="Stretch" SelectedItem="{Binding SelectedGroupToken}" Margin="5 0 0 0">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Label Content="{Binding}"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <!--Group names button grid-->
                    <Grid Grid.Row="2" Margin="0 10 5 0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Content="Remove" Margin="0 0 5 0" Command="{Binding RemoveGroupCommand}" IsEnabled="{Binding SelectedGroup,Converter={StaticResource NullConverter}}"/>
                        <Button Grid.Column="1" Content="Edit" Margin="5 0 5 0" Command="{Binding EditGroupCommand}" IsEnabled="{Binding SelectedGroup,Converter={StaticResource NullConverter}}"/>
                        <Button Grid.Column="2" Content="Add" Margin="5 0 0 0" Command="{Binding AddGroupCommand}"/>
                    </Grid>
                    
                    <!--Token names button grid-->
                    <Grid Grid.Row="2" Grid.Column="1" Margin="5 10 0 0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Content="Remove" Margin="0 0 5 0" Command="{Binding RemoveGroupTokenCommand}" IsEnabled="{Binding SelectedGroupToken, Converter={StaticResource NullConverter}}"/>
                        <Button Grid.Column="2" Content="Add" Margin="5 0 0 0" Command="{Binding AddGroupTokenCommand}" IsEnabled="{Binding SelectedGroup,Converter={StaticResource NullConverter}}"/>
                    </Grid>
                </Grid>
            </TabItem>
        </TabControl>
        
        <!--Ok button grid-->
        <Grid Grid.Row="1" Margin="0 20 0 0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Row="1" Grid.Column="1" Content="Ok">
                <i:Interaction.Triggers>
                    <i:EventTrigger EventName="Click">
                        <i:CallMethodAction MethodName="Close" TargetObject="{Binding RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=Window}}" />
                    </i:EventTrigger>
                </i:Interaction.Triggers>
            </Button>
        </Grid>
    </Grid>
</Window>
