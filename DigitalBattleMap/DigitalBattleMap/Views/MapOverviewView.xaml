<UserControl x:Class="DigitalBattleMap.Views.MapOverviewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:DigitalBattleMap.Views" 
             xmlns:viewmodels="clr-namespace:DigitalBattleMap.ViewModels" xmlns:uielements="clr-namespace:DigitalBattleMap.UIElements"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             Background="White"
             FontSize="17">
    <UserControl.DataContext>
        <viewmodels:MapOverviewViewModel/>
    </UserControl.DataContext>
    <UserControl.Resources>
        <uielements:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </UserControl.Resources>
    <Grid>
        <Image Source="{Binding OverviewBitmapSource}"/>
        <uielements:MouseCanvas  
            Background="Transparent" 
            Cursor="{Binding MouseCanvas.Cursor}" 
            Panel.ZIndex="2"
            LeftButtonDownCommand="{Binding MouseCanvas.LeftButtonDownCommand}"
            LeftButtonUpCommand="{Binding MouseCanvas.LeftButtonUpCommand}"
            RightButtonDownCommand="{Binding MouseCanvas.RightButtonDownCommand}"
            RightButtonUpCommand="{Binding MouseCanvas.RightButtonUpCommand}"
            MouseMoveCommand="{Binding MouseCanvas.MouseMoveCommand}"
            MouseWheelCommand="{Binding MouseCanvas.MouseWheelCommand}">
            <Rectangle 
                Width="{Binding MouseCanvas.SelectionWidth}" 
                Height="{Binding MouseCanvas.SelectionHeight}" 
                Canvas.Left="{Binding MouseCanvas.SelectionX}" 
                Canvas.Top="{Binding MouseCanvas.SelectionY}"
                Visibility="{Binding MouseCanvas.IsSelectionAreaVisible, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter={x:Static Visibility.Hidden}}"
                Fill="#32B8D4F0"
                Stroke="#0078D7"/>
            <Polygon
                Points="{Binding MouseCanvas.PolygonSelectionPoints}"
                Visibility="{Binding MouseCanvas.IsSelectionAreaVisible, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter={x:Static Visibility.Hidden}}"
                Fill="#32B8D4F0"
                Stroke="#0078D7"/>
        </uielements:MouseCanvas>
        <Button Content="Reset" HorizontalAlignment="Right" VerticalAlignment="Bottom" Panel.ZIndex="3" Margin="0 0 5 5" Padding="2" Command="{Binding ResetCommand}"/>
    </Grid>
</UserControl>
