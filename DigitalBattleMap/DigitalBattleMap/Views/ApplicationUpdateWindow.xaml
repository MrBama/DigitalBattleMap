<Window x:Class="DigitalBattleMap.Views.ApplicationUpdateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:viewmodels="clr-namespace:DigitalBattleMap.ViewModels" 
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DigitalBattleMap.Views" 
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors" 
        xmlns:uielements="clr-namespace:DigitalBattleMap.UIElements"
        Title="ApplicationUpdateWindow" Height="450" Width="800"
        FontSize="17"
        WindowStartupLocation="CenterScreen">
    <Window.DataContext>
        <viewmodels:ApplicationUpdateWindowViewModel/>
    </Window.DataContext>
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Label x:Name="TitleLabel" Content="Do not close the application before the update is complete!" FontWeight="Bold" Padding="0"/>
        <ProgressBar Grid.Row="1" Margin="0 10 0 0" Minimum="0" Maximum="{Binding MaximumProgress}" Value="{Binding CurrentProgress}" Height="{Binding ElementName=TitleLabel, Path=ActualHeight}"/>
        <Border Grid.Row="2" Margin="0 10 0 0" BorderThickness="1" BorderBrush="Black">
            <ScrollViewer >
                <i:Interaction.Behaviors>
                    <uielements:ScrollToBottomBehavior />
                </i:Interaction.Behaviors>
                <TextBox FontSize="15" IsReadOnly="True" BorderThickness="0" Text="{Binding UpdateLog}" TextWrapping="WrapWithOverflow"/>
            </ScrollViewer>
        </Border>
            
    </Grid>
</Window>
