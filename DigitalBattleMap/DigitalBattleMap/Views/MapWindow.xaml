<Window x:Class="DigitalBattleMap.Views.MapWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DigitalBattleMap.Views"
        xmlns:viewmodels="clr-namespace:DigitalBattleMap.ViewModels" 
        xmlns:uielements="clr-namespace:DigitalBattleMap.UIElements"
        mc:Ignorable="d"
        Title="MapWindow" Height="1080" Width="1920"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResizeWithGrip"
        Left="{Binding Left, Mode=TwoWay}"
        WindowState="{Binding WindowState, Mode=TwoWay}">
    <Window.DataContext>
        <viewmodels:MapWindowViewModel/>
    </Window.DataContext>
    <Window.Resources>
        <uielements:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Window.Resources>
    
    <Grid Margin="5">
        <Image Source="{Binding BackgroundBitmapSource}"/>
        <Image Source="{Binding GridBitmapSource}"/>
        <Image Source="{Binding TokenBitmapSource}"/>
        <Image Source="{Binding PauseIconBitmapSource}" Width="250" Stretch="Uniform" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="20" Visibility="{Binding IsPaused, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter={x:Static Visibility.Hidden}}" />
    </Grid>
</Window>
