<UserControl x:Class="DigitalBattleMap.Views.FogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:viewmodels="clr-namespace:DigitalBattleMap.ViewModels" 
             xmlns:uielements="clr-namespace:DigitalBattleMap.UIElements"
             mc:Ignorable="d" 
             d:DesignHeight="1080" d:DesignWidth="480"
             Background="White"
             FontSize="17">
    <UserControl.DataContext>
        <viewmodels:FogControllerViewModel/>
    </UserControl.DataContext>
    <UserControl.Resources>
        <uielements:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <uielements:BoolToVisibilityConverter x:Key="InvertedBoolToVisibilityConverter" IsInverted="True"/>
        <uielements:BoolToInvertedBoolConverter x:Key="InvertBoolConverter"/>
    </UserControl.Resources>

    <!-- Background editor grid -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>

        <!-- Fill with fog -->
        <Grid Grid.Row="0" Margin="0 10 0 0" >
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto"/>
            </Grid.ColumnDefinitions>
            <ToggleButton VerticalContentAlignment="Center" Margin="10 0 0 0" IsChecked="{Binding FogShapeCollection.IsFillFogEnabled}" 
                          IsEnabled="{Binding ActiveFogShape.IsDrawingFog, Converter={StaticResource InvertBoolConverter}}" ToolTip="Fill map with fog">
                <Image Source="{Binding FillIconBitmapSource}" MaxHeight="35" Margin="2"/>
            </ToggleButton>
        </Grid>

        <!-- Fog collection label -->
        <Grid Grid.Row="1" Margin="0 10 0 0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Separator BorderThickness="1" BorderBrush="Gray"/>
            <Label Grid.Column="1" Content="Fog Collection" FontSize="20" FontWeight="Bold"/>
            <Separator Grid.Column="2" BorderThickness="1" BorderBrush="Gray"/>
        </Grid>

        <!-- Fog Collection tools-->
        <Grid Grid.Row="2" Margin="0 10 0 0" >
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="auto"/>
            </Grid.ColumnDefinitions>
            <ToggleButton VerticalContentAlignment="Center" Margin="10 0 0 0" IsChecked="{Binding IsSnapToGridEnabled}" 
                          IsEnabled="{Binding ActiveFogShape.IsDrawingFog, Converter={StaticResource InvertBoolConverter}}" 
                          ToolTip="Shape snaps to grid">
                <Image Source="{Binding SnapIconBitmapSource}" MaxHeight="35" Margin="2"/>
            </ToggleButton>
            <ToggleButton Grid.Column="2" VerticalContentAlignment="Center" HorizontalAlignment="Right" Margin="0 0 10 0" 
                          IsChecked="{Binding ActiveFogShape.IsFogEnabled, Converter={StaticResource InvertBoolConverter}}"
                          IsEnabled="{Binding ActiveFogShape.IsDrawingFog, Converter={StaticResource InvertBoolConverter}}"
                          ToolTip="Cut shape out of the fog">
                <Image Source="{Binding CutIconBitmapSource}" MaxHeight="35" Margin="2"/>
            </ToggleButton>
        </Grid>

        <ListView Grid.Row="3" Margin="0 10 0 0" ItemsSource="{Binding FogShapeCollection}" SelectedItem="{Binding SelectedFogShape}" HorizontalContentAlignment="Stretch"
                  IsEnabled="{Binding ActiveFogShape.IsDrawingFog, Converter={StaticResource InvertBoolConverter}}">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Background="Transparent">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="7*"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>

                        <!--Name grid-->
                        <Grid Grid.Column="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="6*" />
                                <ColumnDefinition Width="4*" />
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" x:Name="ShapeNameTextBox" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" FontWeight="Bold" Margin="2"/>
                            <TextBlock Grid.Column="1" Text="{Binding ShapeType}" FontWeight="Bold" Margin="2" HorizontalAlignment="Center"/>
                        </Grid>
                        
                        <!-- Toggle Fog -->
                        <Grid Grid.Column="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto"/>
                            </Grid.ColumnDefinitions>
                            <ToggleButton Content="Enabled" FontWeight="Bold" IsChecked="{Binding IsFogEnabled, Mode=TwoWay}" HorizontalAlignment="Right" Margin="2"/>
                        </Grid>

                        <!-- Delete Fog -->
                        <Grid Grid.Column="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto"/>
                            </Grid.ColumnDefinitions>
                            <ToggleButton IsChecked="{Binding IsDeleted, Mode=TwoWay}" HorizontalAlignment="Center">
                                <Image Source="{Binding DeleteIconBitmapSource}" MaxWidth="25" Margin="2"/>
                            </ToggleButton>
                        </Grid>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <!--Shape selection grid-->
        <Grid Grid.Row="4" Margin="0 10 0 0">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions >
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <ToggleButton Margin="0 0 10 0" Command="{Binding DrawPolygonCommand}" IsChecked="{Binding IsDrawPolygonChecked}" HorizontalContentAlignment="Stretch" HorizontalAlignment="Stretch"
                          IsEnabled="{Binding ActiveFogShape.IsDrawingFog, Converter={StaticResource InvertBoolConverter}}">
                <Image Source="{Binding DrawIconBitmapSource}" Height="50" Margin="2"/>
            </ToggleButton>
            <ToggleButton Grid.Column="1" Margin="10 0 10 0" Command="{Binding AngularPolygonCommand}" IsChecked="{Binding IsAngularPolygonChecked}" HorizontalContentAlignment="Stretch"
                          IsEnabled="{Binding ActiveFogShape.IsDrawingFog, Converter={StaticResource InvertBoolConverter}}">
                <Image Source="{Binding ZigZagIconBitmapSource}" Height="50" Margin="2"/>
            </ToggleButton>
            <ToggleButton Grid.Column="2" Margin="10 0 10 0" Command="{Binding RectangleCommand}" IsChecked="{Binding IsRectangleChecked}" HorizontalContentAlignment="Stretch"
                          IsEnabled="{Binding ActiveFogShape.IsDrawingFog, Converter={StaticResource InvertBoolConverter}}">
                <Image Source="{Binding SquareIconBitmapSource}" Height="50" Margin="2"/>
            </ToggleButton>
            <ToggleButton Grid.Column="3" Margin="10 0 10 0" Command="{Binding CircleCommand}" IsChecked="{Binding IsCircleChecked}" HorizontalContentAlignment="Stretch"
                          IsEnabled="{Binding ActiveFogShape.IsDrawingFog, Converter={StaticResource InvertBoolConverter}}">
                <Image Source="{Binding CircleIconBitmapSource}" Height="50" Margin="2"/>
            </ToggleButton>
            <ToggleButton Grid.Column="4" Margin="10 0 0 0" Command="{Binding NGonCommand}" IsChecked="{Binding IsNGonChecked}" HorizontalContentAlignment="Stretch"
                          IsEnabled="{Binding ActiveFogShape.IsDrawingFog, Converter={StaticResource InvertBoolConverter}}">
                <Image Source="{Binding NGonIconBitmapSource}" Height="50" Margin="2"/>
            </ToggleButton>
        </Grid>

        <Button Grid.Row="5" Content="Clear" Command="{Binding ClearFogCommand}" Margin="0 10 0 0" VerticalAlignment="Bottom"
                IsEnabled="{Binding ActiveFogShape.IsDrawingFog, Converter={StaticResource InvertBoolConverter}}"/>
    </Grid>
</UserControl>
