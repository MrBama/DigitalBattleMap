<Window x:Class="DigitalBattleMap.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DigitalBattleMap" xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
        mc:Ignorable="d"
        Title="MainWindow" Height="900" Width="1700"
        WindowStartupLocation="CenterScreen"
        FontSize="17"
        WindowState="Maximized"
        MinWidth="{x:Static SystemParameters.MaximizedPrimaryScreenWidth}"
        MaxWidth="{x:Static SystemParameters.MaximizedPrimaryScreenWidth}"
        MinHeight="{x:Static SystemParameters.MaximizedPrimaryScreenHeight}"
        MaxHeight="{x:Static SystemParameters.MaximizedPrimaryScreenHeight}">
    <Window.DataContext>
        <local:MainWindowViewModel/>
    </Window.DataContext>

    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Closing">
            <i:InvokeCommandAction Command="{Binding WindowClosingCommand}" />
        </i:EventTrigger>
        <i:EventTrigger EventName="ContentRendered">
            <i:InvokeCommandAction Command="{Binding InkCanvasSizeOnStartupCommand}" CommandParameter="{Binding ElementName=MapCanvas, Path=ActualWidth}"/>
        </i:EventTrigger>
    </i:Interaction.Triggers>

    <!--Main grid-->
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>

        <!--Controls grid-->
        <Grid Margin="0 0 10 0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>

            <!--Tab grid-->
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TabControl Grid.Row="1" BorderBrush="Gray" BorderThickness="0" SelectedIndex="{Binding SelectedTabIndex}">
                    <TabItem Padding="10">
                        <TabItem.Header>
                            <TextBlock Text="Background" FontSize="22" FontWeight="Bold"/>
                        </TabItem.Header>
                        <Border BorderThickness="1" BorderBrush="Gray" CornerRadius="10">
                            <!--Background editor grid-->
                            <Grid Margin="10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="auto"/>
                                    <RowDefinition Height="auto"/>
                                    <RowDefinition Height="auto"/>
                                    <RowDefinition Height="auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <Button Grid.ColumnSpan="2" Content="Open" Command="{Binding OpenBackgroundCommand}"/>
                                <Button Grid.Row="1" Content="Zoom in" Margin="0 10 5 0" Command="{Binding BackgroundZoomInCommand}" IsEnabled="{Binding IsZoomEnabled}"/>
                                <Button Grid.Row="1" Grid.Column="1" Content="Zoom out" Margin="5 10 0 0" Command="{Binding BackgroundZoomOutCommand}" IsEnabled="{Binding IsZoomEnabled}"/>
                                <!--Zoom factor grid-->
                                <Grid Grid.Row="2" Grid.ColumnSpan="2" Margin="0 10 0 0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.5*"/>
                                        <ColumnDefinition Width="7*"/>
                                        <ColumnDefinition Width="1.5*"/>
                                    </Grid.ColumnDefinitions>
                                    <Label Content="Zoom"/>
                                    <Slider Grid.Column="1" VerticalAlignment="Center" Minimum="1" Maximum="100" Value="{Binding BackgroundZoomPercentage, UpdateSourceTrigger=PropertyChanged}" TickFrequency="1" IsSnapToTickEnabled="True"/>
                                    <Label Grid.Column="2" Content="{Binding BackgroundZoomPercentageLabel}" />
                                </Grid>
                                <Button Grid.Row="3" Grid.ColumnSpan="2" Content="Clear" Command="{Binding ClearBackgroundCommand}" Margin="0 10 0 0"/>
                            </Grid>
                        </Border>
                    </TabItem>
                    <TabItem Padding="10">
                        <TabItem.Header>
                            <TextBlock Text="Grid" FontSize="22" FontWeight="Bold"/>
                        </TabItem.Header>
                        <Border BorderThickness="1" BorderBrush="Gray" CornerRadius="10">
                            <!--Grid editor grid-->
                            <Grid Margin="10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="auto"/>
                                    <RowDefinition Height="auto"/>
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="6*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="3*"/>
                                </Grid.ColumnDefinitions>

                                <Label Content="Grid size in pixels"/>
                                <TextBox Grid.Column="1" Text="{Binding GridSize, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center">
                                    <TextBox.InputBindings>
                                        <KeyBinding Command="{Binding GridSizeEnterCommand}" Key="Enter" />
                                    </TextBox.InputBindings>
                                </TextBox>
                                <Label Grid.Row="1" Content="Show grid" Margin="0 10 0 0"/>
                                <CheckBox Grid.Row="1" Grid.Column="1" VerticalAlignment="Center" IsChecked="{Binding IsGridShown}" Margin="0 10 0 0"/>
                            </Grid>
                        </Border>
                    </TabItem>
                    <TabItem Padding="10">
                        <TabItem.Header>
                            <TextBlock Text="Drawing" FontSize="22" FontWeight="Bold"/>
                        </TabItem.Header>
                        <Border BorderThickness="1" BorderBrush="Gray" CornerRadius="10">
                            <!--Drawing grid-->
                            <Grid Margin="10">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="auto"/>
                                    <RowDefinition Height="auto"/>
                                    <RowDefinition Height="auto"/>
                                </Grid.RowDefinitions>
                                
                                <!--Color buttons grid-->
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="auto"/>
                                        <RowDefinition Height="auto"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="2*"/>
                                    </Grid.ColumnDefinitions>
                                    <Image Source="{Binding BlackButtonBitmapSource}" Margin="5 10 15 10" Cursor="Hand">
                                        <i:Interaction.Triggers>
                                            <i:EventTrigger EventName="MouseLeftButtonUp">
                                                <i:InvokeCommandAction Command="{Binding DrawingColorChangedCommand}" CommandParameter="Black" />
                                            </i:EventTrigger>
                                        </i:Interaction.Triggers>
                                    </Image>
                                    <Image Grid.Column="1" Source="{Binding RedButtonBitmapSource}" Margin="5 10 15 10" Cursor="Hand">
                                        <i:Interaction.Triggers>
                                            <i:EventTrigger EventName="MouseLeftButtonUp">
                                                <i:InvokeCommandAction Command="{Binding DrawingColorChangedCommand}" CommandParameter="Red" />
                                            </i:EventTrigger>
                                        </i:Interaction.Triggers>
                                    </Image>
                                    <Image Grid.Column="2" Source="{Binding GreenButtonBitmapSource}" Margin="5 10 15 10" Cursor="Hand">
                                        <i:Interaction.Triggers>
                                            <i:EventTrigger EventName="MouseLeftButtonUp">
                                                <i:InvokeCommandAction Command="{Binding DrawingColorChangedCommand}" CommandParameter="Green" />
                                            </i:EventTrigger>
                                        </i:Interaction.Triggers>
                                    </Image>
                                    <Image Grid.Column="3" Source="{Binding BlueButtonBitmapSource}" Margin="5 10 15 10" Cursor="Hand">
                                        <i:Interaction.Triggers>
                                            <i:EventTrigger EventName="MouseLeftButtonUp">
                                                <i:InvokeCommandAction Command="{Binding DrawingColorChangedCommand}" CommandParameter="Blue" />
                                            </i:EventTrigger>
                                        </i:Interaction.Triggers>
                                    </Image>
                                    <Image Grid.Row="1" Source="{Binding EraserButtonBitmapSource}" Margin="5 10 15 10" Cursor="Hand">
                                        <i:Interaction.Triggers>
                                            <i:EventTrigger EventName="MouseLeftButtonUp">
                                                <i:InvokeCommandAction Command="{Binding DrawingColorChangedCommand}" CommandParameter="Eraser" />
                                            </i:EventTrigger>
                                        </i:Interaction.Triggers>
                                    </Image>

                                    <Image Source="{Binding BlackButtonSelectedBitmapSource}" Margin="5 10 15 10" Cursor="Hand" Visibility="{Binding BlackButtonSelectedVisibility}"/>
                                    <Image Grid.Column="1" Source="{Binding RedButtonSelectedBitmapSource}" Margin="5 10 15 10" Cursor="Hand" Visibility="{Binding RedButtonSelectedVisibility}"/>
                                    <Image Grid.Column="2" Source="{Binding GreenButtonSelectedBitmapSource}" Margin="5 10 15 10" Cursor="Hand" Visibility="{Binding GreenButtonSelectedVisibility}"/>
                                    <Image Grid.Column="3" Source="{Binding BlueButtonSelectedBitmapSource}" Margin="5 10 15 10" Cursor="Hand" Visibility="{Binding BlueButtonSelectedVisibility}"/>
                                    <Image Grid.Row="1" Source="{Binding EraserButtonSelectedBitmapSource}" Margin="5 10 15 10" Cursor="Hand" Visibility="{Binding EraserButtonSelectedVisibility}"/>
                                </Grid>
                                
                                <!--Pen size grid-->
                                <Grid Grid.Row="1" Margin="0 10 0 0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="7*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Label Content="Pen size" />
                                    <Slider Grid.Column="1" VerticalAlignment="Center" Margin="10 0 10 0" Minimum="1" Maximum="100" Value="{Binding PenSize, UpdateSourceTrigger=PropertyChanged}" TickFrequency="1" IsSnapToTickEnabled="True"/>
                                    <TextBox Grid.Column="2" Text="{Binding PenSize, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center"/>
                                </Grid>
                                <Button Grid.Row="2" Content="Clear" Command="{Binding ClearDrawingCommand}" Margin="0 10 0 0"/>
                            </Grid>
                        </Border>
                    </TabItem>
                </TabControl>
            </Grid>

            <!--Control grid-->
            <Border Grid.Row="1" BorderThickness="1" BorderBrush="Gray" CornerRadius="10" Margin="0 5 0 0">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    
                    <Label Grid.ColumnSpan="3" Content="Control" FontSize="22" FontWeight="Bold"/>
                    <Button Grid.Row="1" Grid.ColumnSpan="2" Content="Show map" Margin="0 10 0 0" Command="{Binding ShowMapCommand}"/>
                    <Button Grid.Row="2" Grid.ColumnSpan="2" Content="Clear all" Margin="0 10 0 0" Command="{Binding ClearAllCommand}"/>
                    
                    <!--Map arrows grid-->
                    <Grid Grid.Row="3" Grid.ColumnSpan="2" Margin="0 10 0 0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.5*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="1.5*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="2" Margin="5 0 5 5" Command="{Binding MoveMapArrowCommand}" CommandParameter="Up">
                            <Image Source="{Binding MapArrowUpBitmapSource}"/>
                        </Button>
                        <Button Grid.Column="1" Grid.Row="1" Margin="0 5 5 0" Command="{Binding MoveMapArrowCommand}" CommandParameter="Left">
                            <Image Source="{Binding MapArrowLeftBitmapSource}"/>
                        </Button>
                        <Button Grid.Row="1" Grid.Column="2" Margin="5 5 5 0" Command="{Binding MoveMapArrowCommand}" CommandParameter="Down">
                            <Image Source="{Binding MapArrowDownBitmapSource}"/>
                        </Button>
                        <Button Grid.Row="1" Grid.Column="3" Margin="5 5 0 0" Command="{Binding MoveMapArrowCommand}" CommandParameter="Right">
                            <Image Source="{Binding MapArrowRightBitmapSource}"/>
                        </Button>
                    </Grid>
                </Grid>
            </Border>
            
            <!--Configuration grid-->
            <Border Grid.Row="2" BorderThickness="1" BorderBrush="Gray" CornerRadius="10" Margin="0 5 0 0">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/> 
                        <ColumnDefinition Width="*"/> 
                    </Grid.ColumnDefinitions>
                    <Label Content="Configuration" FontSize="22" FontWeight="Bold"/>

                    <Button Grid.Row="1" Content="Open" Margin="0 10 5 0" Command="{Binding OpenMapCommand}"/>
                    <Button Grid.Row="1" Grid.Column="1" Content="Save" Margin="5 10 0 0" Command="{Binding SaveMapCommand}"/>
                    <Button Grid.Row="2" Grid.ColumnSpan="2" Content="Settings" Command="{Binding SettingsCommand}" Margin="0 10 0 0"/>
                </Grid>
            </Border>
        </Grid>

        <!--Map grid-->
        <Grid Grid.Column="1" >
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="1" BorderThickness="3" BorderBrush="Black">
                <Grid x:Name="MapCanvas">
                    <Image Source="{Binding BackgroundBitmapSource}"/>
                    <Image x:Name="GridLayer" Source="{Binding GridBitmapSource}" Visibility="{Binding GridVisibility}"/>
                    <local:InkCanvasControl Background="{Binding InkCanvasBackgroundBitmapSource}" 
                                            DefaultDrawingAttributes="{Binding InkCanvasDrawingAttributes}" 
                                            Width="{Binding ElementName=GridLayer, Path=ActualWidth}" 
                                            Height="{Binding ElementName=GridLayer, Path=ActualHeight}"
                                            EditingMode="{Binding EditingMode}"
                                            EraserShape="{Binding EraserShape}"
                                            Strokes="{Binding Strokes, Mode=TwoWay}"
                                            Visibility="{Binding InkCanvasVisibility}">
                    </local:InkCanvasControl>
                    <Canvas Visibility="{Binding MouseInputCanvasVisibility}" Background="Transparent" Cursor="Hand">
                        <i:Interaction.Behaviors>
                            <local:MouseBehavior MouseX="{Binding MouseInputX, Mode=OneWayToSource}" MouseY="{Binding MouseInputY, Mode=OneWayToSource}"/>
                        </i:Interaction.Behaviors>
                        <i:Interaction.Triggers>
                            <i:EventTrigger EventName="MouseLeftButtonDown">
                                <i:InvokeCommandAction Command="{Binding MouseInputCanvasDownCommand}" PassEventArgsToCommand="True" />
                            </i:EventTrigger>
                            <i:EventTrigger EventName="MouseLeftButtonUp">
                                <i:InvokeCommandAction Command="{Binding MouseInputCanvasUpCommand}" PassEventArgsToCommand="True" />
                            </i:EventTrigger>
                        </i:Interaction.Triggers>
                    </Canvas>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
