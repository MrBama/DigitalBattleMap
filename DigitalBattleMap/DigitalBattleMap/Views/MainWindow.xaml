<Window x:Class="DigitalBattleMap.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:i="http://schemas.microsoft.com/xaml/behaviors" 
        xmlns:uielements="clr-namespace:DigitalBattleMap.UIElements"
        xmlns:viewmodels="clr-namespace:DigitalBattleMap.ViewModels" 
        xmlns:views="clr-namespace:DigitalBattleMap.Views"
        xmlns:enums="clr-namespace:DigitalBattleMap.DataClasses" 
        mc:Ignorable="d"
        Title="MainWindow" Height="1025" Width="1920" 
        WindowStartupLocation="CenterScreen"
        FontSize="17"
        WindowState="Maximized">
    <Window.DataContext>
        <viewmodels:MainWindowViewModel/>
    </Window.DataContext>
    <Window.Resources>
        <uielements:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <uielements:BoolToVisibilityConverter x:Key="InvertedBoolToVisibilityConverter" IsInverted="True"/>
        <Style x:Key="FocusVisual">
            <Setter Property="Control.Template">
                <Setter.Value>
                    <ControlTemplate>
                        <Rectangle Margin="2" StrokeDashArray="1 2" Stroke="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}" SnapsToDevicePixels="true" StrokeThickness="1"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <SolidColorBrush x:Key="Button.Static.Background" Color="#FFDDDDDD"/>
        <SolidColorBrush x:Key="Button.Static.Border" Color="Black"/>
        <SolidColorBrush x:Key="Button.MouseOver.Background" Color="#FFBEE6FD"/>
        <SolidColorBrush x:Key="Button.MouseOver.Border" Color="#FF3C7FB1"/>
        <SolidColorBrush x:Key="Button.Pressed.Background" Color="#FFC4E5F6"/>
        <SolidColorBrush x:Key="Button.Pressed.Border" Color="#FF2C628B"/>
        <SolidColorBrush x:Key="Button.Disabled.Background" Color="#FFF4F4F4"/>
        <SolidColorBrush x:Key="Button.Disabled.Border" Color="#FFADB2B5"/>
        <SolidColorBrush x:Key="Button.Disabled.Foreground" Color="#FF838383"/>
        <Style x:Key="InfoToggleStyle" TargetType="{x:Type ToggleButton}"> <!-- I wanted a round button :( -->
            <Setter Property="FocusVisualStyle" Value="{StaticResource FocusVisual}"/>
            <Setter Property="Background" Value="{StaticResource Button.Static.Background}"/>
            <Setter Property="BorderBrush" Value="{StaticResource Button.Static.Border}"/>
            <Setter Property="Foreground" Value="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                        <Border x:Name="border" CornerRadius="50" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" SnapsToDevicePixels="true">
                            <ContentPresenter x:Name="contentPresenter" Focusable="False" HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}" Margin="{TemplateBinding Padding}" RecognizesAccessKey="True" SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}" VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Button.IsDefaulted" Value="True">
                                <Setter Property="BorderBrush" TargetName="border" Value="{DynamicResource {x:Static SystemColors.HighlightBrushKey}}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" TargetName="border" Value="{StaticResource Button.MouseOver.Background}"/>
                                <Setter Property="BorderBrush" TargetName="border" Value="{StaticResource Button.MouseOver.Border}"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background" TargetName="border" Value="{StaticResource Button.Pressed.Background}"/>
                                <Setter Property="BorderBrush" TargetName="border" Value="{StaticResource Button.Pressed.Border}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" TargetName="border" Value="{StaticResource Button.Disabled.Background}"/>
                                <Setter Property="BorderBrush" TargetName="border" Value="{StaticResource Button.Disabled.Border}"/>
                                <Setter Property="TextElement.Foreground" TargetName="contentPresenter" Value="{StaticResource Button.Disabled.Foreground}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <i:Interaction.Triggers>
        <i:EventTrigger EventName="Closing">
            <i:InvokeCommandAction Command="{Binding WindowClosingCommand}" />
        </i:EventTrigger>
        <i:EventTrigger EventName="ContentRendered">
            <i:InvokeCommandAction Command="{Binding CanvasSizeOnStartupCommand}" CommandParameter="{Binding ElementName=MapCanvas, Path=ActualWidth}"/>
        </i:EventTrigger>
        <i:EventTrigger EventName="KeyDown">
            <i:InvokeCommandAction Command="{Binding KeyDownCommand}" PassEventArgsToCommand="True"/>
        </i:EventTrigger>
        <i:EventTrigger EventName="KeyUp">
            <i:InvokeCommandAction Command="{Binding KeyUpCommand}" PassEventArgsToCommand="True"/>
        </i:EventTrigger>
    </i:Interaction.Triggers>

    <!--Main grid-->
    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="3*"/>
        </Grid.ColumnDefinitions>

        <!--Tab grid-->
        <Grid>
            <!-- Tab control -->
            <TabControl Margin="0 0 10 0" BorderBrush="Gray" BorderThickness="0" SelectedIndex="{Binding SelectedTabIndex}">
                <TabItem>
                    <TabItem.Header>
                        <Image Source="{Binding CampaignEmblemBitmapSource}" MaxHeight="35" Margin="2"/>
                    </TabItem.Header>
                    <Border BorderThickness="1" BorderBrush="Gray" CornerRadius="10">
                        <views:CampaignView DataContext="{Binding CampaignController}" Margin="10"/>
                    </Border>
                </TabItem>
                <TabItem>
                    <TabItem.Header>
                        <Image Source="{Binding BackgroundEmblemBitmapSource}" MaxHeight="35" Margin="2"/>
                    </TabItem.Header>
                    <Border BorderThickness="1" BorderBrush="Gray" CornerRadius="10">
                        <views:BackgroundView DataContext="{Binding BackgroundController}" Margin="10"/>
                    </Border>
                </TabItem>
                <TabItem>
                    <TabItem.Header>
                        <Image Source="{Binding FogEmblemBitmapSource}" MaxHeight="35" Margin="2"/>
                    </TabItem.Header>
                    <Border BorderThickness="1" BorderBrush="Gray" CornerRadius="10">
                        <views:FogView DataContext="{Binding FogController}" Margin="10"/>
                    </Border>
                </TabItem>
                <TabItem>
                    <TabItem.Header>
                        <Image Source="{Binding DrawingEmblemBitmapSource}" MaxHeight="35" Margin="2"/>
                    </TabItem.Header>
                    <Border BorderThickness="1" BorderBrush="Gray" CornerRadius="10">
                        <views:DrawingView DataContext="{Binding DrawingController}" Margin="10"/>
                    </Border>
                </TabItem>
                <TabItem>
                    <TabItem.Header>
                        <Image Source="{Binding TokenEmblemBitmapSource}" MaxHeight="35" Margin="2"/>
                    </TabItem.Header>
                    <Border BorderThickness="1" BorderBrush="Gray" CornerRadius="10">
                        <views:TokenView DataContext="{Binding TokenController}" Margin="10"/>
                    </Border>
                </TabItem>
            </TabControl>
            <!-- Info button -->
            <ToggleButton Style="{DynamicResource InfoToggleStyle}" IsChecked="{Binding IsInfoEnabled}" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0 5 15 0"
                          ToolTip="When enabled shows the active controls in the top left corner of the map">
                <Image Source="{Binding InfoIconBitmapSource}" Width="30" Height="30" Margin="-3" IsHitTestVisible="False"/>
            </ToggleButton>
        </Grid>

        <!--Map grid-->
        <Grid Grid.Column="1" >
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid>
                <!-- Map and tabs -->
                <TabControl BorderThickness="0" SelectedIndex="{Binding SelectedMapTabIndex}">
                    <TabItem>
                        <TabItem.Header>
                            <TextBlock Text="Map" FontSize="20" FontWeight="Bold"/>
                        </TabItem.Header>

                        <Border x:Name="MapBorder" BorderThickness="3" BorderBrush="Black">
                            <Grid x:Name="MapCanvas">
                                <i:Interaction.Triggers>
                                    <i:EventTrigger EventName="SizeChanged">
                                        <i:InvokeCommandAction Command="{Binding CanvasSizeChangedCommand}" PassEventArgsToCommand="True"/>
                                    </i:EventTrigger>
                                </i:Interaction.Triggers>
                                <Image Source="{Binding BackgroundController.BackgroundBitmapSource}"/>
                                <Image Source="{Binding BackgroundController.GMOverlayBitmapSource}" Opacity="0.5"/>
                                <Image x:Name="GridLayer" Source="{Binding BackgroundController.GridBitmapSource}"/>
                                <!-- Individual stroke geometries to preserve all boundaries -->
                                <ItemsControl ItemsSource="{Binding ShapeComposer.StrokesGeometries}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <Canvas/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <!-- Outer stroke for each geometry -->
                                            <Path Data="{Binding}"
                                                SnapsToDevicePixels="True"
                                                RenderOptions.EdgeMode="Aliased"
                                                Stroke="{Binding DataContext.ShapeComposer.ComposedGeometryOuterStrokeBrush, RelativeSource={RelativeSource AncestorType=Grid}}"
                                                StrokeThickness="{Binding DataContext.ShapeComposer.ComposedGeometryOuterStrokeThickness, RelativeSource={RelativeSource AncestorType=Grid}}"
                                                StrokeLineJoin="Round"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <!-- Inner stroke geometries -->
                                <ItemsControl ItemsSource="{Binding ShapeComposer.StrokesGeometries}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <Canvas/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <!-- Inner stroke for each geometry -->
                                            <Path Data="{Binding}"
                                                SnapsToDevicePixels="True"
                                                RenderOptions.EdgeMode="Aliased"
                                                Stroke="{Binding DataContext.ShapeComposer.ComposedGeometryInnerStrokeBrush, RelativeSource={RelativeSource AncestorType=Grid}}"
                                                StrokeThickness="{Binding DataContext.ShapeComposer.ComposedGeometryInnerStrokeThickness, RelativeSource={RelativeSource AncestorType=Grid}}"
                                                StrokeLineJoin="Round"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <!-- Filled fog shapes -->
                                <Path Fill="Black" Opacity="0.5"
                                    Data="{Binding ShapeComposer.ComposedGeometry}"/>
                                <uielements:FogCanvas
                                    Background="Transparent" 
                                    ActiveShape="{Binding FogController.ActiveFogShape}" 
                                    Cursor="{Binding FogController.ActiveFogShape.Cursor}"
                                    Visibility="{Binding FogCanvasVisibility}"
                                    Panel.ZIndex="{Binding DrawingCanvasZIndex}"
                                    Width="{Binding ElementName=GridLayer, Path=ActualWidth}" 
                                    Height="{Binding ElementName=GridLayer, Path=ActualHeight}">
                                </uielements:FogCanvas>
                                <uielements:DrawingCanvas
                                    Background="Transparent" 
                                    ActiveShape="{Binding DrawingController.ActiveShape}" 
                                    ShapeCollection="{Binding DrawingController.ShapeCollection}" 
                                    Cursor="{Binding DrawingController.ActiveShape.Cursor}"
                                    Visibility="{Binding DrawingCanvasVisibility}"
                                    Panel.ZIndex="{Binding DrawingCanvasZIndex}"
                                    Width="{Binding ElementName=GridLayer, Path=ActualWidth}" 
                                    Height="{Binding ElementName=GridLayer, Path=ActualHeight}">
                                </uielements:DrawingCanvas>
                                <Label 
                                    Content="{Binding DrawingController.ActiveShape.SizeLabel}" 
                                    Margin="{Binding DrawingController.ActiveShape.SizeLabelPosition}" 
                                    Panel.ZIndex="{Binding DrawingCanvasZIndex}"
                                    FontSize="30" 
                                    Padding="0"
                                    FontWeight="Bold"
                                    Foreground="Black"
                                    Background="White"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Top"/>
                                <Image Source="{Binding TokenController.TokenBitmapSource}" Visibility="{Binding TokenVisibility}"/>
                                <Image Source="{Binding TokenController.TokenSelectionBitmapSource}" Visibility="{Binding TokenVisibility}"/>
                                <uielements:MouseCanvas 
                                    Visibility="{Binding MouseInputCanvasVisibility}" 
                                    Background="Transparent" 
                                    Cursor="{Binding MouseCanvas.Cursor}" 
                                    Panel.ZIndex="5"
                                    LeftButtonDownCommand="{Binding MouseCanvas.LeftButtonDownCommand}"
                                    LeftButtonUpCommand="{Binding MouseCanvas.LeftButtonUpCommand}"
                                    RightButtonDownCommand="{Binding MouseCanvas.RightButtonDownCommand}"
                                    RightButtonUpCommand="{Binding MouseCanvas.RightButtonUpCommand}"
                                    MouseMoveCommand="{Binding MouseCanvas.MouseMoveCommand}"
                                    MouseWheelCommand="{Binding MouseCanvas.MouseWheelCommand}">
                                    <Rectangle 
                                        Width="{Binding MouseCanvas.SelectionWidth}" 
                                        Height="{Binding MouseCanvas.SelectionHeight}" 
                                        Canvas.Left="{Binding MouseCanvas.SelectionX}" 
                                        Canvas.Top="{Binding MouseCanvas.SelectionY}"
                                        Visibility="{Binding MouseCanvas.IsSelectionAreaVisible, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter={x:Static Visibility.Hidden}}"
                                        Fill="#32B8D4F0"
                                        Stroke="#0078D7"/>
                                    <Polygon
                                        Points="{Binding MouseCanvas.PolygonSelectionPoints}"
                                        Visibility="{Binding MouseCanvas.IsSelectionAreaVisible, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter={x:Static Visibility.Hidden}}"
                                        Fill="#32B8D4F0"
                                        Stroke="#0078D7"/>
                                </uielements:MouseCanvas>
                            </Grid>
                        </Border>
                    </TabItem>
                    <TabItem>
                        <TabItem.Header>
                            <TextBlock Text="Overview" FontSize="20" FontWeight="Bold"/>
                        </TabItem.Header>

                        <Border BorderThickness="3" BorderBrush="Black" Width="{Binding ElementName=MapBorder, Path=ActualWidth}" Height="{Binding ElementName=MapBorder, Path=ActualHeight}">
                            <views:MapOverviewView DataContext="{Binding MapOverview}"/>
                        </Border>
                    </TabItem>
                    <TabItem Visibility="{Binding HideDungeonMasterFeatures, Converter={StaticResource InvertedBoolToVisibilityConverter}, ConverterParameter={x:Static Visibility.Hidden}}">
                        <TabItem.Header>
                            <TextBlock Text="Statblocks" FontSize="20" FontWeight="Bold"/>
                        </TabItem.Header>
                        <Border BorderThickness="3" BorderBrush="Black" Width="{Binding ElementName=MapBorder, Path=ActualWidth}" Height="{Binding ElementName=MapBorder, Path=ActualHeight}">
                            <views:StatblocksView DataContext="{Binding TokenController.StatblocksViewModel}"/>
                        </Border>
                    </TabItem>
                </TabControl>
                <!-- Info corner -->
                <Canvas IsHitTestVisible="False" Visibility="{Binding IsInfoEnabled, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter={x:Static Visibility.Hidden}}">
                    <!-- Black border around white info text for contrast -->
                    <TextBlock Text="{Binding ControlInfoText}" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="5 40 0 0" FontSize="18" IsHitTestVisible="False"
                           Canvas.Top="2" Canvas.Left="2"/>
                    <TextBlock Text="{Binding ControlInfoText}" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="5 40 0 0" FontSize="18" IsHitTestVisible="False"
                           Canvas.Top="2" Canvas.Left="4"/>
                    <TextBlock Text="{Binding ControlInfoText}" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="5 40 0 0" FontSize="18" IsHitTestVisible="False"
                           Canvas.Top="4" Canvas.Left="2"/>
                    <TextBlock Text="{Binding ControlInfoText}" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="5 40 0 0" FontSize="18" IsHitTestVisible="False"
                           Canvas.Top="4" Canvas.Left="4"/>
                    <TextBlock Text="{Binding ControlInfoText}" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="5 40 0 0" FontSize="18" IsHitTestVisible="False"
                           Canvas.Top="4" Canvas.Left="3"/>
                    <TextBlock Text="{Binding ControlInfoText}" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="5 40 0 0" FontSize="18" IsHitTestVisible="False"
                           Canvas.Top="3" Canvas.Left="4"/>
                    <TextBlock Text="{Binding ControlInfoText}" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="5 40 0 0" FontSize="18" IsHitTestVisible="False"
                           Canvas.Top="2" Canvas.Left="3"/>
                    <TextBlock Text="{Binding ControlInfoText}" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="5 40 0 0" FontSize="18" IsHitTestVisible="False"
                           Canvas.Top="3" Canvas.Left="2"/>
                    <!-- White info text -->
                    <TextBlock Text="{Binding ControlInfoText}" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="5 40 0 0" FontSize="18" IsHitTestVisible="False"
                           Canvas.Top="3" Canvas.Left="3" Foreground="White"/>
                </Canvas>

            </Grid>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!--Control grid-->
                <Border MaxHeight="140" MaxWidth="500" Grid.Column="1" BorderThickness="1" BorderBrush="Gray" CornerRadius="10" Margin="0 10 0 0">
                    <Grid Margin="10 10 10 10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="auto"/>
                        </Grid.ColumnDefinitions>
                        

                        <!--Zoom buttons grid-->
                        <Grid Grid.Column="0" Margin="0 0 10 0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="0.5*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Button x:Name="ZoomInButton" Grid.Row="1" Grid.Column="0" Margin="0 0 5 5" Command="{Binding MapZoomInCommand}" Width="{Binding ElementName=ZoomInButton,Path=ActualHeight}">
                                <Image Source="{Binding MapZoomInBitmapSource}"/>
                            </Button>
                            <Button x:Name="ZoomOutButton" Grid.Row="2" Grid.Column="0" Margin="0 5 5 0" Command="{Binding MapZoomOutCommand}" Width="{Binding ElementName=ZoomOutButton,Path=ActualHeight}">
                                <Image Source="{Binding MapZoomOutBitmapSource}"/>
                            </Button>
                            <Button x:Name="CropButton" Grid.Row="1" Grid.Column="1" Margin="5 0 0 5" Command="{Binding MapCropCommand}" Width="{Binding ElementName=CropButton,Path=ActualHeight}" Background="{Binding CropColor}" >
                                <Image Source="{Binding MapCropBitmapSource}"/>
                            </Button>
                            <Button x:Name="ZoomBackgroundButton" Grid.Row="2" Grid.Column="1" Margin="5 5 0 0" Command="{Binding MapRevertZoomAndMoveCommand}" Width="{Binding ElementName=ZoomBackgroundButton,Path=ActualHeight}" IsEnabled="{Binding ZoomAndMoveHistory.IsPreviousCommandAvailable}">
                                <Image Source="{Binding MapZoomBackgroundBitmapSource}"/>
                            </Button>
                        </Grid>

                        <Border Grid.Column="1" BorderThickness="0.5" BorderBrush="Gray"/>

                        <!--Map arrows grid-->
                        <Grid Grid.Column="2" Margin="5 0 5 0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="0.5*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="auto"/>
                                <ColumnDefinition Width="auto"/>
                                <ColumnDefinition Width="auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <Label Grid.Row="1" Grid.Column="1" Content="{Binding MultiMoveCount}" Visibility="{Binding IsMultiMove, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter={x:Static Visibility.Hidden}}" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" FontSize="30"/>
                            <Button x:Name="MoveUpButton" Grid.Row="1" Grid.Column="2" Margin="5 0 5 5" Command="{Binding MoveMapArrowCommand}" CommandParameter="{x:Static enums:ArrowDirection.Up}" Width="{Binding ElementName=MoveUpButton,Path=ActualHeight}">
                                <Image Source="{Binding MapArrowUpBitmapSource}"/>
                            </Button>
                            <Button x:Name="MoveLeftButton" Grid.Row="2" Grid.Column="1" Margin="5 5 5 0" Command="{Binding MoveMapArrowCommand}" CommandParameter="{x:Static enums:ArrowDirection.Left}" Width="{Binding ElementName=MoveLeftButton,Path=ActualHeight}">
                                <Image Source="{Binding MapArrowLeftBitmapSource}"/>
                            </Button>
                            <Button x:Name="MoveDownButton" Grid.Row="2" Grid.Column="2" Margin="5 5 5 0" Command="{Binding MoveMapArrowCommand}" CommandParameter="{x:Static enums:ArrowDirection.Down}" Width="{Binding ElementName=MoveDownButton,Path=ActualHeight}">
                                <Image Source="{Binding MapArrowDownBitmapSource}"/>
                            </Button>
                            <Button x:Name="MoveRightButton" Grid.Row="2" Grid.Column="3" Margin="5 5 5 0" Command="{Binding MoveMapArrowCommand}" CommandParameter="{x:Static enums:ArrowDirection.Right}" Width="{Binding ElementName=MoveRightButton,Path=ActualHeight}">
                                <Image Source="{Binding MapArrowRightBitmapSource}"/>
                            </Button>
                        </Grid>

                        <Border Grid.Column="3" BorderThickness="0.5" BorderBrush="Gray"/>

                        <!--Show map grid-->
                        <Grid Grid.Column="4" Margin="10 0 0 0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="auto"/>
                                <RowDefinition Height="auto"/>
                            </Grid.RowDefinitions>

                            <Button Grid.Row="1" Content="Show map" Command="{Binding ShowMapCommand}" MinWidth="150"/>
                            <CheckBox Grid.Row="1" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0 0 2 0" IsChecked="{Binding IsShowMapLocked}">
                                <CheckBox.LayoutTransform>
                                    <ScaleTransform ScaleX="1.5" ScaleY="1.5"/>
                                </CheckBox.LayoutTransform>
                            </CheckBox>
                            <Button Grid.Row="2" Content="Clear all" Margin="0 10 0 0" Command="{Binding ClearAllCommand}"/>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
        
        <!--Configuration menu-->
        <Expander Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Bottom" ExpandDirection="Up" IsExpanded="{Binding IsConfigurationMenuExpanded}" Background="White" FlowDirection="RightToLeft">
            <i:Interaction.Triggers>
                <i:EventTrigger EventName="MouseLeave">
                    <i:InvokeCommandAction Command="{Binding HideConfigurationCommand}"/>
                </i:EventTrigger>
            </i:Interaction.Triggers>
            <Expander.Header>
                <TextBlock Text="Settings" Margin="5 0 5 0" FontWeight="Bold">
                    <TextBlock.LayoutTransform>
                        <RotateTransform Angle="0"/>
                    </TextBlock.LayoutTransform>
                </TextBlock>
            </Expander.Header>
            <Border Grid.Column="2" BorderThickness="1" BorderBrush="Gray" CornerRadius="10" MinWidth="250" FlowDirection="LeftToRight">
                <!--Settings grid-->
                <Grid Margin="10 0 10 10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                    </Grid.RowDefinitions>
                    <!--Server status grid-->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="auto"/>
                        </Grid.ColumnDefinitions>
                        <Label Content="Server:"/>
                        <Label Grid.Column="1" Content="{Binding ServerConnectionStatus}" Foreground="{Binding ServerConnectionStatusColor}"/>
                    </Grid>
                    <Button Grid.Row="2" Content="{Binding ServerConnectionButtonText}" Command="{Binding ServerConnectionCommand}" IsEnabled="{Binding ServerConnectionButtonEnabled}"/>
                    <!--Open and save grid-->
                    <Grid Grid.Row="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Content="Open" Margin="0 10 5 0" Command="{Binding OpenMapCommand}"/>
                        <Button Grid.Column="1" Content="Save" Margin="5 10 0 0" Command="{Binding SaveMapCommand}"/>
                    </Grid>
                    <Button Grid.Row="4" Content="Settings" Margin="0 10 0 0" Command="{Binding SettingsCommand}"/>
                </Grid>
            </Border>
        </Expander>
    </Grid>
</Window>
