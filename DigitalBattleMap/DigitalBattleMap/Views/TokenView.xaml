<UserControl x:Class="DigitalBattleMap.Views.TokenView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:uielements="clr-namespace:DigitalBattleMap.UIElements" 
             xmlns:viewmodels="clr-namespace:DigitalBattleMap.ViewModels" 
             xmlns:enums="clr-namespace:DigitalBattleMap.DataClasses" 
             xmlns:enumsCommon="clr-namespace:DigitalBattleMap.Common;assembly=Common" 
             xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
             mc:Ignorable="d" 
             d:DesignHeight="1080" d:DesignWidth="480"
             Background="White"
             FontSize="17">
    <UserControl.DataContext>
        <viewmodels:TokenControllerViewModel/>
    </UserControl.DataContext>
    <UserControl.Resources>
        <uielements:TokenSizeToBoolConverter x:Key="TokenSizeToBoolConverter"/>
        <uielements:TokenOrientationToBoolConverter x:Key="TokenOrientationToBoolConverter"/>
        <uielements:ConditionToBoolConverter x:Key="ConditionToBoolConverter"/>
        <uielements:NullToBoolConverter x:Key="NullConverter"/>
        <uielements:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <uielements:BoolToVisibilityConverter x:Key="InvertedBoolToVisibilityConverter" IsInverted="True"/>
    </UserControl.Resources>
    
    <!--Tokens grid-->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="auto"/>
        </Grid.ColumnDefinitions>

        <Button Content="Custom tokens" Command="{Binding CustomTokensCommand}"/>
        <ListView Grid.Row="1" ItemsSource="{Binding TokenList}" HorizontalContentAlignment="Stretch" Margin="0 10 0 0" SelectedItem="{Binding SelectedToken}" FontSize="14">
            <i:Interaction.Behaviors>
                <uielements:MultiSelectionBehavior SelectedItems="{Binding SelectedTokens, Mode=TwoWay}" SelectedItemsChangedCommand="{Binding SelectedItemsChangedCommand}"/>
                <uielements:ScrollIntoViewBehavior />
            </i:Interaction.Behaviors>
            <ListView.ItemTemplate>
                <DataTemplate>
                    <Grid Background="Transparent">
                        <Grid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Visible" IsChecked="{Binding Visible}" Command="{Binding TokenVisibilityCommand}"/>
                                <MenuItem>
                                    <MenuItem.Header>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <Label Content="Height" Padding="0"/>
                                            <TextBox Grid.Column="1" MinWidth="50" Margin="5 0 0 0" Text="{Binding Height, UpdateSourceTrigger=PropertyChanged}">
                                                <TextBox.InputBindings>
                                                    <KeyBinding Command="{Binding ConditionHeightCommand}" Key="Enter"/>
                                                </TextBox.InputBindings>
                                            </TextBox>
                                        </Grid>
                                    </MenuItem.Header>
                                </MenuItem>
                                <MenuItem Header="Size">
                                    <MenuItem Header="Tiny" IsChecked="{Binding Token.Size, Converter={StaticResource TokenSizeToBoolConverter}, ConverterParameter={x:Static enums:TokenSize.Tiny}}" Command="{Binding TokenSizeChangedCommand}" CommandParameter="{x:Static enums:TokenSize.Tiny}"/>
                                    <MenuItem Header="Small" IsChecked="{Binding Token.Size, Converter={StaticResource TokenSizeToBoolConverter}, ConverterParameter={x:Static enums:TokenSize.Small}}" Command="{Binding TokenSizeChangedCommand}" CommandParameter="{x:Static enums:TokenSize.Small}"/>
                                    <MenuItem Header="Medium" IsChecked="{Binding Token.Size, Converter={StaticResource TokenSizeToBoolConverter}, ConverterParameter={x:Static enums:TokenSize.Medium}}" Command="{Binding TokenSizeChangedCommand}" CommandParameter="{x:Static enums:TokenSize.Medium}"/>
                                    <MenuItem Header="Large" IsChecked="{Binding Token.Size, Converter={StaticResource TokenSizeToBoolConverter}, ConverterParameter={x:Static enums:TokenSize.Large}}" Command="{Binding TokenSizeChangedCommand}" CommandParameter="{x:Static enums:TokenSize.Large}"/>
                                    <MenuItem Header="Huge" IsChecked="{Binding Token.Size, Converter={StaticResource TokenSizeToBoolConverter}, ConverterParameter={x:Static enums:TokenSize.Huge}}" Command="{Binding TokenSizeChangedCommand}" CommandParameter="{x:Static enums:TokenSize.Huge}"/>
                                    <MenuItem Header="Gargantuan" IsChecked="{Binding Token.Size, Converter={StaticResource TokenSizeToBoolConverter}, ConverterParameter={x:Static enums:TokenSize.Gargantuan}}" Command="{Binding TokenSizeChangedCommand}" CommandParameter="{x:Static enums:TokenSize.Gargantuan}"/>
                                </MenuItem>
                                <MenuItem Header="Orientation">
                                    <MenuItem Header="North" IsChecked="{Binding Token.Orientation, Converter={StaticResource TokenOrientationToBoolConverter}, ConverterParameter={x:Static enums:TokenOrientation.North}}" Command="{Binding TokenOrientationChangedCommand}" CommandParameter="{x:Static enums:TokenOrientation.North}"/>
                                    <MenuItem Header="East" IsChecked="{Binding Token.Orientation, Converter={StaticResource TokenOrientationToBoolConverter}, ConverterParameter={x:Static enums:TokenOrientation.East}}" Command="{Binding TokenOrientationChangedCommand}" CommandParameter="{x:Static enums:TokenOrientation.East}"/>
                                    <MenuItem Header="South" IsChecked="{Binding Token.Orientation, Converter={StaticResource TokenOrientationToBoolConverter}, ConverterParameter={x:Static enums:TokenOrientation.South}}" Command="{Binding TokenOrientationChangedCommand}" CommandParameter="{x:Static enums:TokenOrientation.South}"/>
                                    <MenuItem Header="West" IsChecked="{Binding Token.Orientation, Converter={StaticResource TokenOrientationToBoolConverter}, ConverterParameter={x:Static enums:TokenOrientation.West}}" Command="{Binding TokenOrientationChangedCommand}" CommandParameter="{x:Static enums:TokenOrientation.West}"/>
                                </MenuItem>
                                <MenuItem Header="Move to front" Command="{Binding MoveToFrontCommand}"/>
                                <MenuItem Header="Move to back" Command="{Binding MoveToBackCommand}"/>
                                <MenuItem Header="Add to player" Command="{Binding AddToPlayerCommand}"/>
                                <MenuItem Header="{Binding LinkableObject.LinkToTokenButtonText}" Command="{Binding LinkToTokenCommand}"/>
                            </ContextMenu>
                        </Grid.ContextMenu>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                            <RowDefinition Height="auto"/>
                        </Grid.RowDefinitions>
                        
                        <!--Name and Id grid-->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="auto"/>
                                <ColumnDefinition Width="auto"/>
                            </Grid.ColumnDefinitions>
                            <Label Content="{Binding Token.Name}" FontWeight="Bold"/>
                            <Label Grid.Column="1" Content="ID:" HorizontalAlignment="Right" FontWeight="Bold"/>
                            <Label Grid.Column="2" Content="{Binding Id}" FontWeight="Bold"/>
                        </Grid>
                        
                        <!--Initiative and HP grid-->
                        <Grid Grid.Row="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="auto"/>
                                <ColumnDefinition Width="auto"/>
                                <ColumnDefinition Width="auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="auto"/>
                                <ColumnDefinition Width="auto"/>
                                <ColumnDefinition Width="auto"/>
                                <ColumnDefinition Width="auto"/>
                            </Grid.ColumnDefinitions>
                            <Label Content="Initiative"/>
                            <TextBox Grid.Column="1" VerticalContentAlignment="Center" Margin="5 0 0 0" MinWidth="45" Text="{Binding Initiative, UpdateSourceTrigger=PropertyChanged}"/>
                            <Button Grid.Column="2" Content="C" Margin="5 0 5 0" Width="{Binding ActualHeight, RelativeSource={RelativeSource self}}" Command="{Binding ExpandConditionsCommand}"/>
                            <TextBox Grid.Column="4" VerticalContentAlignment="Center" MinWidth="45" Text="{Binding Health.EditorHp, UpdateSourceTrigger=PropertyChanged}" Background="{Binding Health.Color}" 
                                     Visibility="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type UserControl}}, Path=DataContext.HideDungeonMasterFeatures, Converter={StaticResource InvertedBoolToVisibilityConverter}, ConverterParameter={x:Static Visibility.Collapsed}}">
                                <TextBox.InputBindings>
                                    <KeyBinding Command="{Binding Health.HpEnterCommand}" Key="Enter" />
                                    <KeyBinding Command="{Binding Health.HpEscCommand}" Key="Esc" />
                                    <KeyBinding Command="{Binding Health.CtrlZCommand}" Key="Z" Modifiers="Ctrl"/>
                                    <KeyBinding Command="{Binding Health.CtrlYCommand}" Key="Y" Modifiers="Ctrl"/>
                                </TextBox.InputBindings>
                            </TextBox>
                            <Label Grid.Column="5" Content="/"
                                   Visibility="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type UserControl}}, Path=DataContext.HideDungeonMasterFeatures, Converter={StaticResource InvertedBoolToVisibilityConverter}, ConverterParameter={x:Static Visibility.Collapsed}}"/>
                            <TextBox Grid.Column="6" VerticalContentAlignment="Center" MinWidth="45" Text="{Binding Health.EditorMaxHp, UpdateSourceTrigger=PropertyChanged}" Background="{Binding Health.Color}"
                                     Visibility="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type UserControl}}, Path=DataContext.HideDungeonMasterFeatures, Converter={StaticResource InvertedBoolToVisibilityConverter}, ConverterParameter={x:Static Visibility.Collapsed}}">
                                <TextBox.InputBindings>
                                    <KeyBinding Command="{Binding Health.MaxHpEnterCommand}" Key="Enter" />
                                    <KeyBinding Command="{Binding Health.MaxHpEscCommand}" Key="Esc" />
                                </TextBox.InputBindings>
                            </TextBox>
                            <Label Grid.Column="7" Content="HP"
                                   Visibility="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType={x:Type UserControl}}, Path=DataContext.HideDungeonMasterFeatures, Converter={StaticResource InvertedBoolToVisibilityConverter}, ConverterParameter={x:Static Visibility.Collapsed}}"/>
                        </Grid>



                        <!--Conditions grid-->
                        <Grid Grid.Row="2" Visibility="{Binding AreConditionsVisible, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter={x:Static Visibility.Collapsed}}">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="auto"/>
                                <RowDefinition Height="auto"/>
                                <RowDefinition Height="auto"/>
                                <RowDefinition Height="auto"/>
                                <RowDefinition Height="auto"/>
                                <RowDefinition Height="auto"/>
                                <RowDefinition Height="auto"/>
                                <RowDefinition Height="auto"/>
                                <RowDefinition Height="auto"/>
                                <RowDefinition Height="auto"/>
                                <RowDefinition Height="auto"/>
                                <RowDefinition Height="auto"/>
                                <RowDefinition Height="auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <CheckBox Grid.Row="0" Grid.Column="0" Margin="5 10 5 0" Content="Baned" IsChecked="{Binding Conditions, Converter={StaticResource ConditionToBoolConverter}, Mode=OneWay, ConverterParameter={x:Static enumsCommon:Condition.Baned}}" Command="{Binding ConditionChangedCommand}" CommandParameter="{x:Static enumsCommon:Condition.Baned}"/>
                            <CheckBox Grid.Row="0" Grid.Column="1" Margin="5 10 5 0" Content="Blessed" IsChecked="{Binding Conditions, Converter={StaticResource ConditionToBoolConverter}, Mode=OneWay, ConverterParameter={x:Static enumsCommon:Condition.Blessed}}" Command="{Binding ConditionChangedCommand}" CommandParameter="{x:Static enumsCommon:Condition.Blessed}"/>
                            <CheckBox Grid.Row="1" Grid.Column="0" Margin="5 10 5 0" Content="Blinded" IsChecked="{Binding Conditions, Converter={StaticResource ConditionToBoolConverter}, Mode=OneWay, ConverterParameter={x:Static enumsCommon:Condition.Blinded}}" Command="{Binding ConditionChangedCommand}" CommandParameter="{x:Static enumsCommon:Condition.Blinded}"/>
                            <CheckBox Grid.Row="1" Grid.Column="1" Margin="5 10 5 0" Content="Charmed" IsChecked="{Binding Conditions, Converter={StaticResource ConditionToBoolConverter}, Mode=OneWay, ConverterParameter={x:Static enumsCommon:Condition.Charmed}}" Command="{Binding ConditionChangedCommand}" CommandParameter="{x:Static enumsCommon:Condition.Charmed}"/>
                            <CheckBox Grid.Row="2" Grid.Column="0" Margin="5 10 5 0" Content="Concentration" IsChecked="{Binding Conditions, Converter={StaticResource ConditionToBoolConverter}, Mode=OneWay, ConverterParameter={x:Static enumsCommon:Condition.Concentration}}" Command="{Binding ConditionChangedCommand}" CommandParameter="{x:Static enumsCommon:Condition.Concentration}"/>
                            <CheckBox Grid.Row="2" Grid.Column="1" Margin="5 10 5 0" Content="Deafened" IsChecked="{Binding Conditions, Converter={StaticResource ConditionToBoolConverter}, Mode=OneWay, ConverterParameter={x:Static enumsCommon:Condition.Deafened}}" Command="{Binding ConditionChangedCommand}" CommandParameter="{x:Static enumsCommon:Condition.Deafened}"/>
                            <CheckBox Grid.Row="3" Grid.Column="0" Margin="5 10 5 0" Content="Death" IsChecked="{Binding Conditions, Converter={StaticResource ConditionToBoolConverter}, Mode=OneWay, ConverterParameter={x:Static enumsCommon:Condition.Death}}" Command="{Binding ConditionChangedCommand}" CommandParameter="{x:Static enumsCommon:Condition.Death}"/>
                            <CheckBox Grid.Row="3" Grid.Column="1" Margin="5 10 5 0" Content="Exhausted" IsChecked="{Binding Conditions, Converter={StaticResource ConditionToBoolConverter}, Mode=OneWay, ConverterParameter={x:Static enumsCommon:Condition.Exhausted}}" Command="{Binding ConditionChangedCommand}" CommandParameter="{x:Static enumsCommon:Condition.Exhausted}"/>
                            <CheckBox Grid.Row="4" Grid.Column="0" Margin="5 10 5 0" Content="Flying" IsChecked="{Binding Conditions, Converter={StaticResource ConditionToBoolConverter}, Mode=OneWay, ConverterParameter={x:Static enumsCommon:Condition.Flying}}" Command="{Binding ConditionChangedCommand}" CommandParameter="{x:Static enumsCommon:Condition.Flying}"/>
                            <CheckBox Grid.Row="4" Grid.Column="1" Margin="5 10 5 0" Content="Frightened" IsChecked="{Binding Conditions, Converter={StaticResource ConditionToBoolConverter}, Mode=OneWay, ConverterParameter={x:Static enumsCommon:Condition.Frightened}}" Command="{Binding ConditionChangedCommand}" CommandParameter="{x:Static enumsCommon:Condition.Frightened}"/>
                            <CheckBox Grid.Row="5" Grid.Column="0" Margin="5 10 5 0" Content="Grappled" IsChecked="{Binding Conditions, Converter={StaticResource ConditionToBoolConverter}, Mode=OneWay, ConverterParameter={x:Static enumsCommon:Condition.Grappled}}" Command="{Binding ConditionChangedCommand}" CommandParameter="{x:Static enumsCommon:Condition.Grappled}"/>
                            <CheckBox Grid.Row="5" Grid.Column="1" Margin="5 10 5 0" Content="Hasted" IsChecked="{Binding Conditions, Converter={StaticResource ConditionToBoolConverter}, Mode=OneWay, ConverterParameter={x:Static enumsCommon:Condition.Hasted}}" Command="{Binding ConditionChangedCommand}" CommandParameter="{x:Static enumsCommon:Condition.Hasted}"/>
                            <CheckBox Grid.Row="6" Grid.Column="0" Margin="5 10 5 0" Content="Hex" IsChecked="{Binding Conditions, Converter={StaticResource ConditionToBoolConverter}, Mode=OneWay, ConverterParameter={x:Static enumsCommon:Condition.Hex}}" Command="{Binding ConditionChangedCommand}" CommandParameter="{x:Static enumsCommon:Condition.Hex}"/>
                            <CheckBox Grid.Row="6" Grid.Column="1" Margin="5 10 5 0" Content="Highlighted" IsChecked="{Binding Conditions, Converter={StaticResource ConditionToBoolConverter}, Mode=OneWay, ConverterParameter={x:Static enumsCommon:Condition.Highlighted}}" Command="{Binding ConditionChangedCommand}" CommandParameter="{x:Static enumsCommon:Condition.Highlighted}"/>
                            <CheckBox Grid.Row="7" Grid.Column="0" Margin="5 10 5 0" Content="Incapacitated" IsChecked="{Binding Conditions, Converter={StaticResource ConditionToBoolConverter}, Mode=OneWay, ConverterParameter={x:Static enumsCommon:Condition.Incapacitated}}" Command="{Binding ConditionChangedCommand}" CommandParameter="{x:Static enumsCommon:Condition.Incapacitated}"/>
                            <CheckBox Grid.Row="7" Grid.Column="1" Margin="5 10 5 0" Content="Invisible" IsChecked="{Binding Conditions, Converter={StaticResource ConditionToBoolConverter}, Mode=OneWay, ConverterParameter={x:Static enumsCommon:Condition.Invisible}}" Command="{Binding ConditionChangedCommand}" CommandParameter="{x:Static enumsCommon:Condition.Invisible}"/>
                            <CheckBox Grid.Row="8" Grid.Column="0" Margin="5 10 5 0" Content="Mark" IsChecked="{Binding Conditions, Converter={StaticResource ConditionToBoolConverter}, Mode=OneWay, ConverterParameter={x:Static enumsCommon:Condition.Mark}}" Command="{Binding ConditionChangedCommand}" CommandParameter="{x:Static enumsCommon:Condition.Mark}"/>
                            <CheckBox Grid.Row="8" Grid.Column="1" Margin="5 10 5 0" Content="Paralyzed" IsChecked="{Binding Conditions, Converter={StaticResource ConditionToBoolConverter}, Mode=OneWay, ConverterParameter={x:Static enumsCommon:Condition.Paralyzed}}" Command="{Binding ConditionChangedCommand}" CommandParameter="{x:Static enumsCommon:Condition.Paralyzed}"/>
                            <CheckBox Grid.Row="9" Grid.Column="0" Margin="5 10 5 0" Content="Petrified" IsChecked="{Binding Conditions, Converter={StaticResource ConditionToBoolConverter}, Mode=OneWay, ConverterParameter={x:Static enumsCommon:Condition.Petrified}}" Command="{Binding ConditionChangedCommand}" CommandParameter="{x:Static enumsCommon:Condition.Petrified}"/>
                            <CheckBox Grid.Row="9" Grid.Column="1" Margin="5 10 5 0" Content="Poisoned" IsChecked="{Binding Conditions, Converter={StaticResource ConditionToBoolConverter}, Mode=OneWay, ConverterParameter={x:Static enumsCommon:Condition.Poisoned}}" Command="{Binding ConditionChangedCommand}" CommandParameter="{x:Static enumsCommon:Condition.Poisoned}"/>
                            <CheckBox Grid.Row="10" Grid.Column="0" Margin="5 10 5 0" Content="Prone" IsChecked="{Binding Conditions, Converter={StaticResource ConditionToBoolConverter}, Mode=OneWay, ConverterParameter={x:Static enumsCommon:Condition.Prone}}" Command="{Binding ConditionChangedCommand}" CommandParameter="{x:Static enumsCommon:Condition.Prone}"/>
                            <CheckBox Grid.Row="10" Grid.Column="1" Margin="5 10 5 0" Content="Restrained" IsChecked="{Binding Conditions, Converter={StaticResource ConditionToBoolConverter}, Mode=OneWay, ConverterParameter={x:Static enumsCommon:Condition.Restrained}}" Command="{Binding ConditionChangedCommand}" CommandParameter="{x:Static enumsCommon:Condition.Restrained}"/>
                            <CheckBox Grid.Row="11" Grid.Column="0" Margin="5 10 5 0" Content="Stabilized" IsChecked="{Binding Conditions, Converter={StaticResource ConditionToBoolConverter}, Mode=OneWay, ConverterParameter={x:Static enumsCommon:Condition.Stabilized}}" Command="{Binding ConditionChangedCommand}" CommandParameter="{x:Static enumsCommon:Condition.Stabilized}"/>
                            <CheckBox Grid.Row="11" Grid.Column="1" Margin="5 10 5 0" Content="Stunned" IsChecked="{Binding Conditions, Converter={StaticResource ConditionToBoolConverter}, Mode=OneWay, ConverterParameter={x:Static enumsCommon:Condition.Stunned}}" Command="{Binding ConditionChangedCommand}" CommandParameter="{x:Static enumsCommon:Condition.Stunned}"/>
                            <CheckBox Grid.Row="12" Grid.Column="0" Margin="5 10 5 0" Content="Unconcious" IsChecked="{Binding Conditions, Converter={StaticResource ConditionToBoolConverter}, Mode=OneWay, ConverterParameter={x:Static enumsCommon:Condition.Unconcious}}" Command="{Binding ConditionChangedCommand}" CommandParameter="{x:Static enumsCommon:Condition.Unconcious}"/>
                            <Button Grid.Row="12" Grid.Column="1" Margin="5 10 5 0" Content="Clear all" Command="{Binding ClearAllConditionsCommand}"/>
                        </Grid>
                    </Grid>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>
        
        <!--Up, down, undo and redo grid-->
        <Grid Grid.Row="2" Margin="0 10 0 0">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button Margin="0 0 7.5 0" Height="{Binding ElementName=AddTokenButton, Path=ActualHeight}" IsEnabled="{Binding IsInitiativeUpButtonEnabled}" Command="{Binding TokenUpCommand}">
                <Image Source="{Binding MapArrowUpBitmapSource}"/>
            </Button>
            <Button Grid.Column="1" Margin="2.5 0 5 0" Height="{Binding ElementName=AddTokenButton, Path=ActualHeight}" IsEnabled="{Binding IsInitiativeDownButtonEnabled}" Command="{Binding TokenDownCommand}">
                <Image Source="{Binding MapArrowDownBitmapSource}"/>
            </Button>
            <Button Grid.Column="2" Margin="5 0 2.5 0" Height="{Binding ElementName=AddTokenButton, Path=ActualHeight}" Command="{Binding UndoTokenMoveCommand}" IsEnabled="{Binding TokenMoveHistory.IsPreviousCommandAvailable}">
                <Image Source="{Binding UndoBitmapSource}"/>
            </Button>
            <Button Grid.Column="3" Margin="7.5 0 0 0" Height="{Binding ElementName=AddTokenButton, Path=ActualHeight}" Command="{Binding RedoTokenMoveCommand}" IsEnabled="{Binding TokenMoveHistory.IsNextCommandAvailable}">
                <Image Source="{Binding RedoBitmapSource}"/>
            </Button>
            <Button x:Name="AddTokenButton" Grid.Row="1" Grid.ColumnSpan="2" Content="Add" Margin="0 10 5 0" Command="{Binding AddTokenCommand}"/>
            <Button Grid.Row="1" Grid.Column="2" Grid.ColumnSpan="2" Content="Remove" Margin="5 10 0 0" Command="{Binding RemoveTokenCommand}" IsEnabled="{Binding SelectedToken, Converter={StaticResource NullConverter}}"/>
        </Grid>
        
        <Button Grid.Row="3" Content="Sort initiative" Margin="0 10 0 0" Command="{Binding SortInitiativeCommand}"/>
        <Button Grid.Row="4" Content="Clear" Margin="0 10 0 0" Command="{Binding ClearTokensCommand}"/>
    </Grid>
</UserControl>
